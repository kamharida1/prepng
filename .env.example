# Paystack — https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook URL (shared across your Paystack apps): https://your-domain.com/api/paystack/webhook
# PrepNG routes events via metadata.app=prepng and references prefixed prepng-

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack public key (safe for client-side use)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxx

# Real past questions API — https://questions.aloc.com.ng (free tier: 7,000 calls)
ALOC_ACCESS_TOKEN=your-aloc-access-token
