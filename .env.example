# Public site URL (production)
NEXT_PUBLIC_SITE_URL=https://prepng.com

# Google Search Console — HTML tag verification (content value only, not the full meta tag)
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Paystack — https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxx
# Webhook URL in Paystack Dashboard → Settings → Webhooks:
# https://prepng.com/api/paystack/webhook

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Real past questions API — https://questions.aloc.com.ng (free tier: 7,000 calls)
ALOC_ACCESS_TOKEN=your-aloc-access-token

# Termii SMS (phone OTP via PrepNG API — no Supabase SMS hook needed)
# Use the DND route for OTP; ask Termii support to enable it on your account.
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=PrepNG
# Base URL from your Termii dashboard (often https://api.ng.termii.com)
TERMII_BASE_URL=https://api.ng.termii.com
# dnd = transactional OTP (recommended); generic = promotional only
TERMII_CHANNEL=dnd
# Secret for hashing OTP codes (generate a long random string)
PHONE_OTP_SECRET=your-random-otp-secret
